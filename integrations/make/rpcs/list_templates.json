{
  "url": "/api/v1/templates?target_app=make",
  "method": "GET",
  "headers": {
    "Authorization": "Bearer {{connection.accessToken}}"
  },
  "qs": {
    "client_id": "{{common.clientId}}",
    "client_secret": "{{common.clientSecret}}"
  },
  "response": {
    "iterate": "{{body.data}}",
    "output": {
      "label": "{{item.name}}",
      "value": "{{item.id}}"
    }
  }
}
