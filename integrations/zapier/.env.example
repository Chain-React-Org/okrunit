# Zapier OAuth 2.0 credentials (set in Zapier Developer Platform or via `zapier env:set`)
CLIENT_ID=your_oauth_client_id
CLIENT_SECRET=your_oauth_client_secret

# Your OKRunit production URL (set in Zapier Developer Platform environment)
OKRUNIT_URL=https://okrunit.com
# IMPORTANT: do not use https://www.okrunit.com here. The platform 308-redirects
# www -> apex and HTTP clients strip the Authorization header on cross-host
# redirects, breaking the OAuth Bearer auth check.

# For running tests locally
BASE_URL=http://localhost:3000
ACCESS_TOKEN=your_test_access_token_here
